# Server-only Bailian credentials. Never prefix these with NEXT_PUBLIC_.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus

# OpenAI Sites can require oai-authenticated-user-email on model API routes.
# For other deployments, keep the API behind equivalent access control.
PDF_AUDIT_REQUIRE_AUTH=true
PDF_AUDIT_DATA_DIR=
PDF_AUDIT_PDF_RETENTION_HOURS=72
PDF_AUDIT_WORKER_CONCURRENCY=3
PDF_AUDIT_WORKER_POLL_MS=1000
PDF_AUDIT_SINGLE_TENANT_OWNER=
